{
  "name": "login-stability-monitor",
  "version": "1.0.0",
  "description": "API sanity scripts: single-shot login check and job flows",
  "main": "login-stability-check.js",
  "scripts": {
    "start": "node login-stability-check.js",
    "sanity": "node sanity-job-flow.js",
    "job:new": "node -e \"delete process.env.JOB_TITLE; require('./sanity-job-flow')\"",
    "job:details": "node sanity-job-flow.js --job-details",
    "sanity:print-payload": "node sanity-job-flow.js --print-payload",
    "sanity:stage2": "node sanity-job-next-stage.js",
    "outreach:test": "node outreach-test-flow.js",
    "outreach:template": "node outreach-sequence-template-flow.js",
    "sequence:reply-diag": "node sequence-reply-diagnostics.js"
  },
  "keywords": [
    "api",
    "stability",
    "monitoring",
    "axios"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "dotenv": "^16.4.5"
  }
}

