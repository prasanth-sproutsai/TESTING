BASE_URL=https://your-api-domain.com
LOGIN_USERNAME=your_username_or_email
PASSWORD=your_password

# Optional runtime tuning
INTERVAL_MS=60000
DURATION_HOURS=12
REQUEST_TIMEOUT_MS=15000
LOG_DIR=logs
LOG_FILE=login-stability.log

# Sanity flow: login → create job (see sanity-job-flow.js)
# Required if /user/auth does not return organization._id (common on dev.api):
# ORG_ID=your_organization_object_id
# JOB_CREATE_PATH=/job/create
# JOB_COMPANY=Your Company Name
# JOB_LOCATION=Remote
# SANITY_LOG_FILE=logs.txt
