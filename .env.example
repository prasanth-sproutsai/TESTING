BASE_URL=https://your-api-domain.com
# Browser-like GET headers (Stage 4/5 auto-source); matches test.app.sproutsai.com curls
# JOB_REQUEST_ORIGIN=https://test.app.sproutsai.com
# JOB_REQUEST_REFERER=https://test.app.sproutsai.com/
# JOB_REQUEST_USER_AGENT=Mozilla/5.0 ...
LOGIN_USERNAME=your_username_or_email
PASSWORD=your_password

# login-stability-check.js: one POST /user/auth then exit (Jenkins / post-deploy).
# Optional: REQUEST_TIMEOUT_MS, LOG_DIR, LOG_FILE
REQUEST_TIMEOUT_MS=15000
LOG_DIR=logs
LOG_FILE=login-stability.log

# Sanity flow: login → create job (see sanity-job-flow.js)
# Required if /user/auth does not return organization._id (common on dev.api):
# ORG_ID=your_organization_object_id
# JOB_CREATE_PATH=/job/create
# GET after create (default matches test.app curl): /job/job_details/{id}?status=active
# JOB_DETAILS_PATH=/job/job_details
# JOB_DETAILS_QUERY=status=active
# Alternate API style: JOB_DETAILS_PATH=/job/details  (and clear query if not needed)
# npm run job:details -- <jobId>  OR  JOB_DETAILS_JOB_ID=<jobId> npm run job:details (no arg)
# Stage 4: GET /job/get_auto_source_filter/:jobId (after job details validation)
# JOB_AUTO_SOURCE_FILTER_PATH=/job/get_auto_source_filter
# JOB_AUTO_SOURCE_FILTER_MAX_ATTEMPTS=3
# JOB_AUTO_SOURCE_FILTER_BACKOFF_MS=1000
# SANITY_LOG_FILTER_FULL=1
# Persist Stage 4 output before Stage 5 read
# SAVE_AUTO_SOURCE_FILTER_PATH=/job/save-auto-source-filter
# Stage 6: POST /automation/pipeline/sourcing
# SOURCING_PATH=/automation/pipeline/sourcing
# SOURCING_CANDIDATE_COUNT=20
# SOURCING_MAX_ATTEMPTS=3
# SOURCING_BACKOFF_MS=1000
# SOURCING_COOLDOWN_MS=0
# Stage 7: GET /job/get_match_profiles/:jobId
# MATCH_PROFILES_PATH=/job/get_match_profiles
# MATCH_PROFILES_METHOD=POST
# MATCH_PROFILES_SOURCE=Prospect
# MATCH_PROFILES_THUMBS_UP=0
# MATCH_PROFILES_LIMIT=20
# MATCH_PROFILES_PAGE=1
# MATCH_PROFILES_MAX_ATTEMPTS=3
# MATCH_PROFILES_BACKOFF_MS=1000
# Stage 8: outreach (Step A generate content, Step B create/send sequence)
# GENERATE_PERSONALIZED_EMAIL_PATH=/email/email-templates/generate-personalized-email
# SEQUENCE_CREATE_PATH=/sequence/job/create
# OUTREACH_SUBJECT=Exciting opportunity
# OUTREACH_BODY=We found your profile interesting
# SEQUENCE_ID=your_sequence_id
# FROM_EMAIL=you@company.com
# FROM_EMAIL_ADDRESS=you@company.com
# ORG_NAME=SproutsAI
# Safety toggle: keep outreach OFF unless explicitly needed
# OUTREACH_ENABLED=0
# Stage 5: GET /job/auto-source-filter/:jobId (persisted filter after Stage 4)
# JOB_SAVED_AUTO_SOURCE_FILTER_PATH=/job/auto-source-filter
# JOB_SAVED_AUTO_SOURCE_FILTER_404_RETRIES=3
# JOB_SAVED_AUTO_SOURCE_FILTER_404_DELAY_MIN_MS=5000
# JOB_SAVED_AUTO_SOURCE_FILTER_404_DELAY_MAX_MS=10000
# Require saved filter skills to be non-empty before Stage 6 sourcing trigger
# JOB_SAVED_AUTO_SOURCE_FILTER_REQUIRE_SKILLS_READY=true
# Optional pause after Stage 04 before first GET saved filter (ms)
# JOB_SAVED_AUTO_SOURCE_FILTER_POST_GENERATE_MS=5000
# If GET /job/auto-source-filter stays 404 until UI saves, skip Stage 5 temporarily:
# SANITY_SKIP_SAVED_AUTO_SOURCE_FILTER=1
# Optional: fix title (otherwise random software role each run)
# JOB_TITLE=Senior Backend Developer
# JOB_COMPANY=SproutsAI
# JOB_LOCATION=Bengaluru, Karnataka
# JOB_TYPE=Full-time
# JOB_HEADCOUNT=1
# JOB_SALARY_CURRENCY=INR
# JOB_SALARY_CURRENCY=USD
# JOB_HOSTNAME=test.app.sproutsai.com
# SANITY_LOG_FILE=logs.txt
# SANITY_PRINT_PAYLOAD=1
# JOB_POSTED_LIST_PATH=/job/posted
